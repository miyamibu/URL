{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "DENO_INSTALL=$PWD/.deno curl -fsSL https://deno.land/install.sh | sh && pip install --upgrade -r requirements-media-resolver.txt"
  },
  "deploy": {
    "startCommand": "PATH=$PWD/.deno/bin:$PATH python3 scripts/media_resolver_backend.py",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
