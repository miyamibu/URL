// Copy to ios/Config/URLSaverSecrets.xcconfig for local Archive/TestFlight builds.
// ios/Config/URLSaverSecrets.xcconfig is gitignored. Do not commit real values.
// Use a Supabase publishable key or legacy anon key. Never use service_role or sb_secret keys.

// Keep false for the local-only v1.0 store release. Set true only for a future
// cloud-sharing release after production Supabase/account-deletion prep is done.
URLSAVER_SHARED_TAG_CLOUD_ENABLED = false
URLSAVER_SUPABASE_URL = https:/$()/<project-ref>.supabase.co
URLSAVER_SUPABASE_ANON_KEY = <supabase publishable or legacy anon key>
URLSAVER_INVITE_LINK_BASE_URL = https:/$()/miyamibu.xyz
